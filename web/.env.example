# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# MCP / Cron authentication (shared secret for MCP server & Hermes cron)
MCP_API_KEY=

# Vercel Cron — required for daily reddit-heat-scan on Vercel.
# Set the same value in Vercel → Settings → Environment Variables.
# Vercel automatically sends: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/en/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/en/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/en
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/en
NEXT_PUBLIC_CLERK_SIGN_OUT_FALLBACK_REDIRECT_URL=/en/sign-in

# DashScope / Hermes (AI Agent chat)
DASHSCOPE_API_KEY=
HERMES_MODEL=qwen-plus

# Tavily — optional web search for AI Agent (https://tavily.com)
TAVILY_API_KEY=

# Reddit API — https://www.reddit.com/prefs/apps (script app, optional fallback)
# User-Agent example: PeptideMonitor/0.1 by your_reddit_username
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=PeptideMonitor/0.1 by your_reddit_username

# Apify — https://console.apify.com/account/integrations (recommended for Reddit)
APIFY_API_TOKEN=
# Optional: default trudax/reddit-scraper-lite
APIFY_REDDIT_ACTOR=trudax/reddit-scraper-lite
# Optional: default crawlerbros/google-news-scraper
APIFY_GOOGLE_NEWS_ACTOR=crawlerbros/google-news-scraper
# Engagement refresh uses the same Actor with post URL startUrls (max 40/day)
